# Add to your ~/.gitconfig
# [include]
#   path = ~/.config/.gitconfig-globals

[credential]
  helper = store

[alias]
  unstage = reset HEAD --
  steal = "!f() { git merge $1 --no-commit --no-ff && rm .git/MERGE_HEAD; }; f"
  cleanup = "!f() { \
    git fetch --prune; \
    branches=$(git branch -vv | grep ': gone]' | awk '{print $2}'); \
    if [ -z \"$branches\" ]; then \
        echo \"No branches to delete.\"; \
        exit 0; \
    fi; \
    if [ \"$1\" = \"-f\" ]; then \
        git worktree remove $branches; \
        echo \"$branches\" | xargs git branch -D; \
    else \
        git worktree remove $branches; \
        echo \"$branches\" | xargs git branch -d; \
    fi; \
    git worktree prune; \
}; f"
  d = !git checkout dev && git pull
  m = !git checkout main && git pull
  fomo = !git fetch origin dev:dev && git merge dev
  amend = !git commit --amend --no-edit
  yeet = !git commit -a --amend --no-edit && git push --force-with-lease

[rerere]
  enabled = true
