# Add to your ~/.gitconfig
# [include]
#   path = ~/.config/.gitconfig-globals

[credential]
  helper = store

[alias]
  unstage = reset HEAD --
  steal = "!f() { git merge $1 --no-commit --no-ff && rm .git/MERGE_HEAD; }; f"
  cleanup = "!f() { \
    git fetch --prune; \
    branches=$(git branch -vv | awk '/: gone]/ {sub(/^[*+ ]+/, \"\"); print $1}'); \
    if [ -z \"$branches\" ]; then \
        echo \"No branches to delete.\"; \
        return 0; \
    fi; \
    echo \"$branches\" | while read -r branch; do \
        wt=$(git worktree list --porcelain \
            | awk -v b=\"refs/heads/$branch\" '/^worktree /{p=$0; sub(/^worktree /,\"\",p)} /^branch /{if($2==b) print p}'); \
        if [ -n \"$wt\" ]; then \
            echo \"Removing worktree: $wt\"; \
            git worktree remove \"$wt\" 2>/dev/null || git worktree remove --force \"$wt\"; \
        fi; \
    done; \
    if [ \"$1\" = \"-f\" ]; then \
        echo \"$branches\" | xargs git branch -D; \
    else \
        echo \"$branches\" | xargs git branch -d; \
    fi; \
    git worktree prune; \
}; f"
  d = !git checkout dev && git pull
  m = !git checkout main && git pull
  fomo = !git fetch origin dev:dev && git merge dev
  amend = !git commit --amend --no-edit
  yeet = !git commit -a --amend --no-edit && git push --force-with-lease

[rerere]
  enabled = true
