// niri config — migrated from Hyprland (~/.config/hypr)
// KDL format: https://kdl.dev  |  Docs: https://yalter.github.io/niri/
// Validate after editing: niri validate
//
// NOTE ON PARADIGM: niri is a *scrolling* tiling compositor. There are no
// dwindle splits, no window groups/titlebars (hyprbars), no blur, and no
// per-window focus-dependent opacity. Windows live in columns that scroll
// horizontally; workspaces stack vertically and are dynamic. Bindings below
// keep your Hyprland muscle memory where a sensible equivalent exists; items
// with no equivalent are called out with "NOTE:".

/////////////
/// INPUT ///
/////////////

input {
    keyboard {
        xkb {
            layout "de"
        }
        // repeat-rate 25 matches Hyprland's repeat_rate; delay is niri's default.
        repeat-rate 50
        repeat-delay 600
    }

    touchpad {
        tap
        // Hyprland had natural_scroll = false, so we leave natural-scroll off.
    }

    mouse {}

    // Hyprland: follow_mouse = 1 + mouse_refocus = true
    focus-follows-mouse

    // Hyprland had cursor:no_warps = true, so we do NOT warp-mouse-to-focus.
}

///////////////
/// OUTPUTS ///
///////////////

// Hyprland: monitor = DP-1, 5120x1440@119.97, auto, 1, bitdepth 10, cm srgb
// NOTE: niri does not expose 10-bit depth / color management config — that
// setting is dropped. Everything else carries over. vrr=2 (on-demand) below.
output "DP-1" {
    mode "5120x1440@119.970"
    scale 1
    transform "normal"
    variable-refresh-rate on-demand=true
}

///////////////////
/// ENVIRONMENT ///
///////////////////

// Migrated from Hyprland `env =` lines.
environment {
    TERMINAL "ghostty"
    XCURSOR_SIZE "24"

    LIBVA_DRIVER_NAME "nvidia"
    __GLX_VENDOR_LIBRARY_NAME "nvidia"
    NVD_BACKEND "direct"

    ELECTRON_OZONE_PLATFORM_HINT "auto"
    QT_QPA_PLATFORM "wayland"
    QT_QPA_PLATFORMTHEME "gtk3"
    QT_QPA_PLATFORMTHEME_QT6 "gtk3"

    GTK_THEME "adw-gtk3-dark"
    ICON_THEME "Hicolor"
    COLOR_SCHEME "prefer-dark"

    // NOTE: DISPLAY is intentionally NOT set here — niri's managed
    // xwayland-satellite block (below) assigns the X display and exports
    // DISPLAY to spawned apps itself. Hardcoding it would break X11 apps.
}

////////////////
/// XWAYLAND ///
////////////////

// Hyprland has built-in XWayland; niri uses xwayland-satellite (auto-managed).
// REQUIRED for X11 apps (e.g. Steam): install it first —
//   sudo pacman -S xwayland-satellite
// Comment this block out if you don't need X11 support.
xwayland-satellite {
    path "/usr/bin/xwayland-satellite"
}

//////////////
/// LAYOUT ///
//////////////

layout {
    // Hyprland: gaps_in = 0, gaps_out = 0
    gaps 0

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    // Focus ring stands in for Hyprland's window border (border_size = 2).
    // Colors from noctalia-colors.conf (Rose Pine): active = $primary,
    // inactive = $surface.
    focus-ring {
        width 2
        active-color "#ebbcba"
        inactive-color "#191724"
    }

    border {
        off
        width 2
        active-color "#ebbcba"
        inactive-color "#191724"
        urgent-color "#eb6f92"
    }

    // Hyprland had a drop shadow (range 4, rgba(00000070)). Approximated here.
    shadow {
        on
        softness 15
        spread 2
        offset x=0 y=5
        color "#00000070"
    }

    struts {}
}

// Hyprland: decoration.rounding = 13. Applied to all windows below.
window-rule {
    geometry-corner-radius 13
    clip-to-geometry true
}

// NOTE (dropped, no niri equivalent):
//   - decoration.blur (incl. layerrules for noctalia/vicinae) — niri has no blur.
//   - inactive_opacity 0.95 — niri's `opacity` window rule is static, not
//     focus-dependent; there is no "dim unfocused windows".
//   - hyprbars titlebars + their close/fullscreen/minimize buttons.

//////////////////
/// WORKSPACES ///
//////////////////

// A named workspace is needed so app-pinning window rules can target it.
// (Hyprland pinned spotify/steam/signal to workspace 1 "silent".)
workspace "1"

/////////////////
/// AUTOSTART ///
/////////////////

// Migrated from Hyprland `exec-once`. Dropped: `hyprpm reload` (Hyprland
// plugin manager, N/A). waybar is intentionally NOT started — you use noctalia.
spawn-at-startup "easyeffects" "--gapplication-service"
spawn-at-startup "qs" "-c" "noctalia-shell"
spawn-at-startup "hypridle"

// CPU cooler settings (need shell for sleep/&&).
spawn-sh-at-startup "sleep 2 && liquidctl --match h150i set fan speed 25 5 30 15 35 40 38 70 40 100"
spawn-sh-at-startup "sleep 3 && liquidctl initialize --match h150i --pump-mode performance"

// Startup apps.
spawn-at-startup "ghostty"
spawn-at-startup "zen-browser"
spawn-at-startup "signal-desktop"

//////////////
/// MISC   ///
//////////////

hotkey-overlay {
    // skip-at-startup
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Hyprland disabled the anime wallpaper / logo; niri has none, nothing to do.

// prefer-no-csd left OFF so GTK/Electron apps (nautilus, zen, code, signal)
// keep their own client-side decorations, matching your Hyprland look.
// Uncomment to have niri draw bare borders around all windows instead.
// prefer-no-csd

animations {
    // niri's animation system differs from Hyprland's beziers; using tuned
    // defaults rather than porting the 15 custom curves.
}

////////////////////
/// WINDOW RULES ///
////////////////////

// spotify / steam / signal -> workspace 1 (Hyprland: workspace 1 silent).
window-rule {
    match app-id="spotify"
    match app-id="steam"
    match app-id=r#"(?i)signal"#
    open-on-workspace "1"
}

// Firefox / Zen picture-in-picture floats.
window-rule {
    match app-id=r#"(?i)firefox$"# title="^Picture-in-Picture$"
    match app-id=r#"(?i)zen"# title="^Picture-in-Picture$"
    open-floating true
}

// Blender's file dialog opens tiny in Hyprland; give floating Blender windows
// a reasonable size. NOTE: niri can't match "is a floating dialog" like
// Hyprland's match:float, so this targets Blender broadly — tweak if needed.
window-rule {
    match app-id=r#"(?i)blender"#
    open-floating true
    default-column-width { fixed 1400; }
    default-window-height { fixed 900; }
}

////////////////
/// KEYBINDS ///
////////////////

binds {
    // ---- Help ----
    Mod+F1 { show-hotkey-overlay; }

    // ---- Window management ----
    // NOTE: Hyprland used dontkillsteam.sh to avoid killing Steam; niri just
    // closes the focused window.
    Mod+Q repeat=false { close-window; }
    Alt+F4 repeat=false { close-window; }

    // Session exit. NOTE: Hyprland ran `hyde-shell logout`; niri's quit shows a
    // confirmation dialog. (noctalia session menu can be bound here instead.)
    Ctrl+Alt+Delete { quit; }

    Mod+W { toggle-window-floating; }            // Hyprland: togglefloating
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    // Hyprland groups -> niri tabbed columns.
    Mod+G { toggle-column-tabbed-display; }      // Hyprland: togglegroup
    Mod+Ctrl+G { expel-window-from-column; }     // Hyprland: moveoutofgroup

    // Cycle tabs/windows within a column (Hyprland: changegroupactive).
    //Alt+Tab { focus-window-down; }
    //Alt+Shift+Tab { focus-window-up; }

    Mod+F { fullscreen-window; }                 // Hyprland: fullscreen
    Mod+Shift+F { maximize-column; }
    Mod+M { maximize-window-to-edges; }

    // Hyprland: layoutmsg togglesplit (no niri equivalent) — repurposed to
    // cycle preset column widths.
    // Mod+R { switch-preset-column-width; }
    // Mod+Shift+R { switch-preset-column-width-back; }
    // Mod+Ctrl+R { reset-window-height; }
    // Mod+Ctrl+Shift+R { switch-preset-window-height; }

    // niri extras (consume/expel into columns — no Hyprland analog).
    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Ctrl+C { center-column; }

    // NOTE: mouse move/resize (Hyprland binddm Super+LMB/RMB and Super+Z/X)
    // is built into niri: hold Mod and drag with left mouse to move, right
    // mouse to resize. No config binding needed.

    // ---- Focus ----
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }
    Mod+H     { focus-column-left; }
    Mod+L     { focus-column-right; }
    Mod+K     { focus-window-up; }
    Mod+J     { focus-window-down; }
    Mod+Ctrl+Tab { focus-column-right; }         // Hyprland: cyclenext (approx)

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }

    // ---- Resize active window (Hyprland: resizeactive 30) ----
    // Mod+Shift+Right { set-column-width "+30"; }
    // Mod+Shift+Left  { set-column-width "-30"; }
    // Mod+Shift+Up    { set-window-height "-30"; }
    // Mod+Shift+Down  { set-window-height "+30"; }
    // Finer % adjustments (niri idiom).
    // Mod+Minus { set-column-width "-10%"; }
    // Mod+Equal { set-column-width "+10%"; }
    // Mod+Shift+Minus { set-window-height "-10%"; }
    // Mod+Shift+Equal { set-window-height "+10%"; }

    // ---- Move active window within workspace ----
    // Hyprland: Super+Shift+Ctrl+arrows (movewindow / move floating by px).
    // Mod+Shift+Ctrl+Left  { move-column-left; }
    // Mod+Shift+Ctrl+Right { move-column-right; }
    // Mod+Shift+Ctrl+Up    { move-window-up; }
    // Mod+Shift+Ctrl+Down  { move-window-down; }

    // ---- Launchers ----
    Mod+T hotkey-overlay-title="Terminal: ghostty" { spawn "ghostty" "+new-window"; }
    Mod+E hotkey-overlay-title="Files: nautilus" { spawn "nautilus" "--new-window"; }
    // Mod+C hotkey-overlay-title="Editor: code" { spawn "code"; }
    Mod+B hotkey-overlay-title="Browser: zen" { spawn "zen-browser"; }

    // ---- Noctalia shell (compositor-agnostic IPC — unchanged from Hyprland) ----
    Mod+Space { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
    Mod+I { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "controlCenter" "toggle"; }
    Mod+Comma { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "settings" "toggle"; }
    Mod+V { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "clipboard"; }
    Mod+Ctrl+Shift+D { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "darkMode" "toggle"; }
    Mod+Alt+G { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "powerProfile" "toggleNoctaliaPerformance"; }

    // ---- Audio / brightness / media (via noctalia + playerctl) ----
    XF86AudioRaiseVolume allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "increase"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "decrease"; }
    XF86AudioMute        allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "muteOutput"; }
    XF86MonBrightnessUp   allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "increase"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "decrease"; }
    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }

    // ---- Screen capture ----
    // Hyprland used hyprshot (Hyprland-only); niri has built-in screenshots.
    Mod+Shift+S { screenshot; }                  // interactive region/window
    Mod+S { screenshot-window; }
    Mod+Ctrl+Shift+S { screenshot-screen; }
    Print { screenshot; }
    // Color picker (Hyprland: hyprpicker). niri's picker copies hex to clipboard.
    Mod+Shift+C { spawn-sh "niri msg pick-color | grep -oiE '#([0-9a-f]{6})' | head -1 | tr -d '\\n' | wl-copy"; }

    // ---- Overview (replaces hyprexpo) ----
    Mod+O repeat=false { toggle-overview; }

    // ---- Workspaces: focus by number ----
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+0 { focus-workspace 10; }

    // ---- Relative workspace navigation ----
    // Mod+Ctrl+Down { focus-workspace-down; }      // Hyprland: workspace r+1
    // Mod+Ctrl+Up   { focus-workspace-up; }        // Hyprland: workspace r-1
    Mod+Alt+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+Alt+WheelScrollUp   cooldown-ms=150 { focus-workspace-up; }

    // ---- Move window to workspace by number ----
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }
    Mod+Shift+0 { move-column-to-workspace 10; }

    // ---- Move window to workspace "silently" (Hyprland: movetoworkspacesilent) ----
    Mod+Alt+1 { move-column-to-workspace 1 focus=false; }
    Mod+Alt+2 { move-column-to-workspace 2 focus=false; }
    Mod+Alt+3 { move-column-to-workspace 3 focus=false; }
    Mod+Alt+4 { move-column-to-workspace 4 focus=false; }
    Mod+Alt+5 { move-column-to-workspace 5 focus=false; }
    Mod+Alt+6 { move-column-to-workspace 6 focus=false; }
    Mod+Alt+7 { move-column-to-workspace 7 focus=false; }
    Mod+Alt+8 { move-column-to-workspace 8 focus=false; }
    Mod+Alt+9 { move-column-to-workspace 9 focus=false; }
    Mod+Alt+0 { move-column-to-workspace 10 focus=false; }

    // ---- Move window to relative workspace ----
    Mod+Ctrl+Alt+Down { move-column-to-workspace-down; }
    Mod+Ctrl+Alt+Up   { move-column-to-workspace-up; }
    Mod+Shift+WheelScrollDown { move-column-to-workspace-down; }
    Mod+Shift+WheelScrollUp   { move-column-to-workspace-up; }

    // ---- Reorder workspaces (closest to Hyprland's swap-workspaces.sh) ----
    // NOTE: niri workspaces are dynamic with no fixed numbered positions, so
    // the exact "move current workspace to position N" (Mod+Ctrl+N) behavior
    // isn't portable. move-workspace-up/down is the nearest equivalent.
    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }

    // NOTE: scratchpad / special workspace (Hyprland Super+^) has no niri
    // equivalent. Use floating windows (Mod+W) instead.

    // ---- System ----
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Mod+Shift+P { power-off-monitors; }
}
